digraph "ttak_matrix"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  Node1 [id="Node000001",label="ttak_matrix",height=0.2,width=0.4,color="gray40", fillcolor="grey60", style="filled", fontcolor="black",tooltip="Matrix structure for up to 4x4."];
  Node2 -> Node1 [id="edge3_Node000001_Node000002",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=" elements",fontcolor="grey" ];
  Node2 [id="Node000002",label="ttak_bigreal",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$structttak__bigreal.html",tooltip="Arbitrary-precision real number engine. Represents value = mantissa * 10^exponent."];
  Node3 -> Node2 [id="edge4_Node000002_Node000003",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=" mantissa",fontcolor="grey" ];
  Node3 [id="Node000003",label="ttak_bigint",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$structttak__bigint.html",tooltip="Arbitrary-precision integer engine with Small Stack Optimization (SSO)."];
}
